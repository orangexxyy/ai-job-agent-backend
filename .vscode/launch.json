{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "AI Job Agent Backend (FastAPI 8001)",
      "type": "debugpy",
      "request": "launch",
      "module": "uvicorn",
      "args": [
        "app.main:app",
        "--reload",
